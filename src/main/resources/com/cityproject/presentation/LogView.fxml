<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cityproject.presentation.LogController"
      spacing="10" style="-fx-background-color:#1e1e2e; -fx-padding:16; -fx-border-color: #333; -fx-border-width: 0 1 0 0;"
      prefWidth="200"
      maxHeight="Infinity">
    
    <Label text="Event Log" style="-fx-text-fill:#aaa; -fx-font-size:11; -fx-font-weight: bold;"/>
    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" 
                style="-fx-background:#13131f; -fx-background-color:#13131f; -fx-border-color:transparent;">
        <VBox fx:id="logContainer" spacing="4" style="-fx-background-color:#13131f; -fx-padding:5;"/>
    </ScrollPane>
              
</VBox>
