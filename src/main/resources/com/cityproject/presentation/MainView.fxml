<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<!-- 
    MainView.fxml - La vista principale dell'applicazione che organizza i componenti principali dell'interfaccia utente: la barra delle statistiche in alto, la griglia centrale e i controlli laterali.
    Utilizza un BorderPane per posizionare i componenti in modo chiaro e ordinato, con include per StatsView.fxml, GridView.fxml e ControlsView.fxml.
    Il controller associato è MainController.java che gestisce l'interazione tra i componenti e aggiorna la vista in base allo stato della città.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cityproject.presentation.MainController"
            prefWidth="1100" prefHeight="700">

    <top>
        <fx:include fx:id="statsView" source="StatsView.fxml"/>
    </top>

    <center>
        <fx:include fx:id="gridView" source="GridView.fxml"/>
    </center>

    <right>
        <HBox>
            <fx:include fx:id="logView" source="LogView.fxml"/>
            <fx:include fx:id="controlsView" source="ControlsView.fxml"/>
        </HBox>
    </right>

</BorderPane>